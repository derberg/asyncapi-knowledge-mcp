# Large generated artifacts — stored in Git LFS (GitHub rejects files >100MB).
# Regenerated by refresh.yml ONLY when .opencrane/chunks.json actually changed.
.opencrane/embeddings.json filter=lfs diff=lfs merge=lfs -text
.opencrane/milvus.db filter=lfs diff=lfs merge=lfs -text
# vectors.bin is ~19.6k chunks x 1536 dims x 4B — will exceed 100MB once generated
data/vectors.bin filter=lfs diff=lfs merge=lfs -text
