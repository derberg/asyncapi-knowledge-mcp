# Vercel AI Gateway API key — get one at https://vercel.com/docs/ai-gateway
# Used implicitly by the @ai-sdk/gateway provider.
AI_GATEWAY_API_KEY=

# Comma-separated allowed origins, ENFORCED server-side (403 for any request
# whose Origin is missing or not listed), in addition to setting CORS headers.
# "*" disables the check (local dev only) — ALWAYS set the real static site
# origin in production, e.g. ALLOWED_ORIGINS=https://chat.asyncapi.com
ALLOWED_ORIGINS=*

# Override the default chat model routed through the AI Gateway (optional)
# CHAT_MODEL=openai/gpt-5-nano

# Max agent loop iterations (tool-call rounds before fallback message)
# MAX_TOOL_ROUNDS=4

# ---------------------------------------------------------------------------
# Local development (offline mode) — set by scripts/run-local.sh automatically.
# These are only needed if you want to wire the offline plumbing manually.
# Production deployments use AI_GATEWAY_API_KEY only.
# ---------------------------------------------------------------------------

# Use a locally running OpenCrane MCP server for search instead of the
# in-process vector index (run: uvx opencrane serve --transport http)
# SEARCH_MCP_URL=http://localhost:8000/mcp

# Use an OpenAI-compatible endpoint for inference (e.g. local Ollama)
# instead of the Vercel AI Gateway. CHAT_MODEL is required when this is set.
# CHAT_MODEL_BASE_URL=http://localhost:11434/v1
# CHAT_MODEL=mistral-small3.2
# CHAT_MODEL_API_KEY=ollama
